{
  "version": 8,
  "name": "Propify Real Estate Light",
  "metadata": {
    "propify:purpose": "Premium real-estate property detail map optimized for nearby-place evaluation.",
    "propify:theme": "light",
    "maptiler:sourceSchema": "OpenMapTiles",
    "maptiler:replaceToken": "{MAPTILER_KEY}"
  },
  "center": [106.7009, 10.7769],
  "zoom": 13,
  "pitch": 0,
  "bearing": 0,
  "glyphs": "https://api.maptiler.com/fonts/{fontstack}/{range}.pbf?key={MAPTILER_KEY}",
  "sprite": "https://api.maptiler.com/maps/streets-v2/sprite",
  "sources": {
    "maptiler": {
      "type": "vector",
      "url": "https://api.maptiler.com/tiles/v3/tiles.json?key={MAPTILER_KEY}"
    },
    "property": {
      "type": "geojson",
      "data": {
        "type": "FeatureCollection",
        "features": []
      }
    },
    "nearby-radius": {
      "type": "geojson",
      "data": {
        "type": "FeatureCollection",
        "features": []
      }
    },
    "route-preview": {
      "type": "geojson",
      "data": {
        "type": "FeatureCollection",
        "features": []
      }
    }
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#f6f4ef"
      }
    },
    {
      "id": "landcover-park",
      "type": "fill",
      "source": "maptiler",
      "source-layer": "landcover",
      "minzoom": 5,
      "filter": ["in", ["get", "class"], ["literal", ["wood", "grass", "park", "scrub"]]],
      "paint": {
        "fill-color": "#d6ead0",
        "fill-opacity": ["interpolate", ["linear"], ["zoom"], 6, 0.45, 13, 0.72]
      }
    },
    {
      "id": "landuse-public",
      "type": "fill",
      "source": "maptiler",
      "source-layer": "landuse",
      "minzoom": 10,
      "filter": ["in", ["get", "class"], ["literal", ["school", "hospital", "university", "park", "cemetery"]]],
      "paint": {
        "fill-color": [
          "match",
          ["get", "class"],
          "school",
          "#e3edff",
          "university",
          "#e3edff",
          "hospital",
          "#ffe6e4",
          "park",
          "#d6ead0",
          "#eee8df"
        ],
        "fill-opacity": 0.8
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "maptiler",
      "source-layer": "water",
      "paint": {
        "fill-color": "#b7dfff"
      }
    },
    {
      "id": "waterway",
      "type": "line",
      "source": "maptiler",
      "source-layer": "waterway",
      "minzoom": 11,
      "paint": {
        "line-color": "#9bd2f6",
        "line-width": ["interpolate", ["linear"], ["zoom"], 11, 0.7, 16, 2.2],
        "line-opacity": 0.85
      }
    },
    {
      "id": "aeroway",
      "type": "fill",
      "source": "maptiler",
      "source-layer": "aeroway",
      "minzoom": 11,
      "paint": {
        "fill-color": "#ebe6de",
        "fill-opacity": 0.72
      }
    },
    {
      "id": "building-footprints",
      "type": "fill",
      "source": "maptiler",
      "source-layer": "building",
      "minzoom": 14,
      "paint": {
        "fill-color": "#ddd8d0",
        "fill-opacity": ["interpolate", ["linear"], ["zoom"], 14, 0.45, 17, 0.78]
      }
    },
    {
      "id": "building-3d",
      "type": "fill-extrusion",
      "source": "maptiler",
      "source-layer": "building",
      "minzoom": 15,
      "paint": {
        "fill-extrusion-color": "#d7d1c7",
        "fill-extrusion-height": ["interpolate", ["linear"], ["zoom"], 15, 0, 16, ["coalesce", ["get", "render_height"], ["get", "height"], 12]],
        "fill-extrusion-base": ["coalesce", ["get", "render_min_height"], ["get", "min_height"], 0],
        "fill-extrusion-opacity": ["interpolate", ["linear"], ["zoom"], 15, 0, 16, 0.38]
      }
    },
    {
      "id": "road-minor-casing",
      "type": "line",
      "source": "maptiler",
      "source-layer": "transportation",
      "minzoom": 13,
      "filter": ["in", ["get", "class"], ["literal", ["minor", "service", "track", "path"]]],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#efeae2",
        "line-width": ["interpolate", ["linear"], ["zoom"], 13, 1.2, 17, 5],
        "line-opacity": 0.9
      }
    },
    {
      "id": "road-minor",
      "type": "line",
      "source": "maptiler",
      "source-layer": "transportation",
      "minzoom": 13,
      "filter": ["in", ["get", "class"], ["literal", ["minor", "service", "track", "path"]]],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#ffffff",
        "line-width": ["interpolate", ["linear"], ["zoom"], 13, 0.75, 17, 3.2],
        "line-opacity": 0.95
      }
    },
    {
      "id": "road-major-casing",
      "type": "line",
      "source": "maptiler",
      "source-layer": "transportation",
      "filter": ["in", ["get", "class"], ["literal", ["primary", "secondary", "tertiary", "trunk", "motorway"]]],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#e3dbcf",
        "line-width": ["interpolate", ["linear"], ["zoom"], 7, 1.2, 12, 3.5, 16, 8],
        "line-opacity": 0.9
      }
    },
    {
      "id": "road-major",
      "type": "line",
      "source": "maptiler",
      "source-layer": "transportation",
      "filter": ["in", ["get", "class"], ["literal", ["primary", "secondary", "tertiary", "trunk", "motorway"]]],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": ["match", ["get", "class"], "motorway", "#f2d49b", "trunk", "#f3dcae", "#ffffff"],
        "line-width": ["interpolate", ["linear"], ["zoom"], 7, 0.8, 12, 2.4, 16, 5.8]
      }
    },
    {
      "id": "rail-transit",
      "type": "line",
      "source": "maptiler",
      "source-layer": "transportation",
      "minzoom": 10,
      "filter": ["in", ["get", "class"], ["literal", ["rail", "transit", "subway"]]],
      "paint": {
        "line-color": "#8b5cf6",
        "line-width": ["interpolate", ["linear"], ["zoom"], 10, 0.6, 16, 2],
        "line-opacity": 0.5,
        "line-dasharray": [1, 1.2]
      }
    },
    {
      "id": "route-preview-glow",
      "type": "line",
      "source": "route-preview",
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#0ea5e9",
        "line-width": ["interpolate", ["linear"], ["zoom"], 11, 5, 17, 11],
        "line-opacity": 0.18
      }
    },
    {
      "id": "route-preview",
      "type": "line",
      "source": "route-preview",
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#0284c7",
        "line-width": ["interpolate", ["linear"], ["zoom"], 11, 2, 17, 5],
        "line-opacity": 0.82
      }
    },
    {
      "id": "nearby-radius-fill",
      "type": "fill",
      "source": "nearby-radius",
      "paint": {
        "fill-color": "#38bdf8",
        "fill-opacity": 0.08
      }
    },
    {
      "id": "nearby-radius-line",
      "type": "line",
      "source": "nearby-radius",
      "paint": {
        "line-color": "#0ea5e9",
        "line-width": 1.5,
        "line-opacity": 0.35,
        "line-dasharray": [2, 2]
      }
    },
    {
      "id": "poi-education",
      "type": "circle",
      "source": "maptiler",
      "source-layer": "poi",
      "minzoom": 12,
      "filter": ["in", ["get", "class"], ["literal", ["school", "university", "college", "kindergarten"]]],
      "paint": {
        "circle-color": "#2563eb",
        "circle-radius": ["interpolate", ["linear"], ["zoom"], 12, 3, 16, 6],
        "circle-stroke-color": "#ffffff",
        "circle-stroke-width": 1.5,
        "circle-opacity": ["interpolate", ["linear"], ["zoom"], 12, 0.55, 15, 0.95]
      }
    },
    {
      "id": "poi-healthcare",
      "type": "circle",
      "source": "maptiler",
      "source-layer": "poi",
      "minzoom": 12,
      "filter": ["in", ["get", "class"], ["literal", ["hospital", "clinic", "pharmacy", "doctors", "dentist"]]],
      "paint": {
        "circle-color": "#ef6f6c",
        "circle-radius": ["interpolate", ["linear"], ["zoom"], 12, 3, 16, 6],
        "circle-stroke-color": "#ffffff",
        "circle-stroke-width": 1.5,
        "circle-opacity": ["interpolate", ["linear"], ["zoom"], 12, 0.55, 15, 0.95]
      }
    },
    {
      "id": "poi-shopping",
      "type": "circle",
      "source": "maptiler",
      "source-layer": "poi",
      "minzoom": 13,
      "filter": ["in", ["get", "class"], ["literal", ["supermarket", "mall", "convenience", "marketplace", "department_store"]]],
      "paint": {
        "circle-color": "#f59e0b",
        "circle-radius": ["interpolate", ["linear"], ["zoom"], 13, 3, 16, 5.5],
        "circle-stroke-color": "#ffffff",
        "circle-stroke-width": 1.4,
        "circle-opacity": 0.9
      }
    },
    {
      "id": "poi-transport",
      "type": "circle",
      "source": "maptiler",
      "source-layer": "poi",
      "minzoom": 12,
      "filter": ["in", ["get", "class"], ["literal", ["bus_stop", "subway", "railway_station", "train_station", "airport"]]],
      "paint": {
        "circle-color": "#8b5cf6",
        "circle-radius": ["interpolate", ["linear"], ["zoom"], 12, 2.8, 16, 5.5],
        "circle-stroke-color": "#ffffff",
        "circle-stroke-width": 1.4,
        "circle-opacity": 0.88
      }
    },
    {
      "id": "poi-lifestyle-food",
      "type": "circle",
      "source": "maptiler",
      "source-layer": "poi",
      "minzoom": 15,
      "filter": ["in", ["get", "class"], ["literal", ["restaurant", "cafe", "gym", "fitness_centre", "playground", "cinema"]]],
      "paint": {
        "circle-color": ["match", ["get", "class"], "restaurant", "#d97706", "cafe", "#d97706", "#22c55e"],
        "circle-radius": ["interpolate", ["linear"], ["zoom"], 15, 2.5, 17, 4.8],
        "circle-stroke-color": "#ffffff",
        "circle-stroke-width": 1.2,
        "circle-opacity": 0.82
      }
    },
    {
      "id": "poi-label-priority",
      "type": "symbol",
      "source": "maptiler",
      "source-layer": "poi",
      "minzoom": 14,
      "filter": ["in", ["get", "class"], ["literal", ["school", "university", "kindergarten", "hospital", "clinic", "pharmacy", "supermarket", "mall", "marketplace", "bus_stop", "subway", "railway_station", "train_station"]]],
      "layout": {
        "text-field": ["coalesce", ["get", "name:vi"], ["get", "name:en"], ["get", "name"]],
        "text-font": ["Roboto Medium", "Arial Unicode MS Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 14, 10, 17, 12],
        "text-offset": [0, 1.1],
        "text-anchor": "top",
        "text-max-width": 8,
        "text-optional": true
      },
      "paint": {
        "text-color": "#334155",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1.4,
        "text-opacity": ["interpolate", ["linear"], ["zoom"], 14, 0, 15, 0.9]
      }
    },
    {
      "id": "place-label-city",
      "type": "symbol",
      "source": "maptiler",
      "source-layer": "place",
      "filter": ["in", ["get", "class"], ["literal", ["city", "town"]]],
      "layout": {
        "text-field": ["coalesce", ["get", "name:vi"], ["get", "name:en"], ["get", "name"]],
        "text-font": ["Roboto Medium", "Arial Unicode MS Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 5, 13, 11, 18],
        "text-max-width": 10
      },
      "paint": {
        "text-color": "#475569",
        "text-halo-color": "#f6f4ef",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "road-label",
      "type": "symbol",
      "source": "maptiler",
      "source-layer": "transportation_name",
      "minzoom": 13,
      "layout": {
        "symbol-placement": "line",
        "text-field": ["coalesce", ["get", "name:vi"], ["get", "name:en"], ["get", "name"]],
        "text-font": ["Roboto Regular", "Arial Unicode MS Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 13, 10, 17, 12],
        "text-pitch-alignment": "viewport",
        "text-rotation-alignment": "map"
      },
      "paint": {
        "text-color": "#7c756b",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1.2,
        "text-opacity": ["interpolate", ["linear"], ["zoom"], 13, 0.45, 16, 0.9]
      }
    },
    {
      "id": "property-radius-glow",
      "type": "circle",
      "source": "property",
      "paint": {
        "circle-color": "#0ea5e9",
        "circle-radius": ["interpolate", ["linear"], ["zoom"], 11, 24, 16, 52],
        "circle-blur": 0.85,
        "circle-opacity": ["case", ["boolean", ["feature-state", "selected"], false], 0.26, 0.14]
      }
    },
    {
      "id": "property-marker-shadow",
      "type": "circle",
      "source": "property",
      "paint": {
        "circle-color": "#0f172a",
        "circle-radius": ["interpolate", ["linear"], ["zoom"], 11, 10, 16, 16],
        "circle-translate": [0, 3],
        "circle-blur": 0.5,
        "circle-opacity": 0.22
      }
    },
    {
      "id": "property-marker",
      "type": "circle",
      "source": "property",
      "paint": {
        "circle-color": ["case", ["boolean", ["feature-state", "selected"], false], "#0284c7", "#0ea5e9"],
        "circle-radius": ["interpolate", ["linear"], ["zoom"], 11, 8, 16, 13],
        "circle-stroke-color": "#ffffff",
        "circle-stroke-width": 3
      }
    },
    {
      "id": "property-label",
      "type": "symbol",
      "source": "property",
      "minzoom": 11,
      "layout": {
        "text-field": ["coalesce", ["get", "label"], "BDS dang xem"],
        "text-font": ["Roboto Bold", "Arial Unicode MS Bold"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 11, 12, 16, 14],
        "text-offset": [0, -1.6],
        "text-anchor": "bottom",
        "text-allow-overlap": true
      },
      "paint": {
        "text-color": "#0f172a",
        "text-halo-color": "#ffffff",
        "text-halo-width": 2
      }
    }
  ]
}
